{
  "name": "qa-tnr-playwright",
  "version": "1.0.0",
  "description": "TNR UI Ellisphere - Playwright",
  "main": "config/playwright.config.js",
  "scripts": {
    "test": "playwright test --config=config/playwright.config.js",
    "ui": "playwright test --config=config/playwright.config.js --ui",
    "tnr:ua": "playwright test --config=config/playwright.config.js --grep @tnr --project=chromium-ua-ellipro-risk",
    "tnr:prod": "playwright test --config=config/playwright.config.js --grep @tnr --project=chromium-prod-ellipro-risk",
    "smoke:ua": "playwright test --config=config/playwright.config.js --grep @smoke",
    "smoke:prod": "playwright test --config=config/playwright.config.js --grep @smoke --project=chromium-prod-ellipro-risk",
    "tnr:ellipro-risk:ua": "playwright test --config=config/playwright.config.js apps/ellipro-risk/tests",
    "tnr:compliance:ua": "playwright test --config=config/playwright.config.js apps/compliance/tests",
    "tnr:orange:ua": "playwright test --config=config/playwright.config.js apps/orange/tests",
    "tnr:auth": "playwright test --config=config/playwright.config.js --grep @auth",
    "report": "playwright show-report playwright-report"
  },
  "keywords": ["playwright", "tnr", "ellisphere", "qa"],
  "author": "Cellule de Test Ellisphere",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "dotenv": "^17.2.3"
  }
}